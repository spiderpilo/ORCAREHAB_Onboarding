QBO_CLIENT_ID=your-quickbooks-app-client-id
QBO_CLIENT_SECRET=your-quickbooks-app-client-secret
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Encrypts SSN/bank/W-4 fields at rest. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-a-64-character-hex-string

# Signs the HR/Payroll admin login session. Any long random string works.
SESSION_SECRET=replace-with-a-long-random-string

# Single shared HR/Payroll login. Generate the hash with:
# node scripts/hash-password.js "your-new-password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-output-of-hash-password-script

# Optional: email notification to HR/Payroll when a new submission arrives.
# Leave blank to skip notifications entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
ADMIN_DASHBOARD_URL=http://localhost:4000/admin
